{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orgschema.com/r19/aggregated_results.schema.json",
  "title": "R19 Aggregated Results",
  "description": "Aggregated results file (r19_results.json). Generated by run19_rate_sweep.py.",
  "type": "object",
  "required": [
    "meta",
    "per_cell",
    "model_rd",
    "hypotheses"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["n_total_records", "n_valid_records", "models", "rate_conditions", "brands"],
      "properties": {
        "generated": {"type": "string"},
        "n_total_records": {"type": "integer", "minimum": 0},
        "n_valid_records": {"type": "integer", "minimum": 0},
        "models": {"type": "array", "items": {"type": "string"}},
        "rate_conditions": {"type": "array", "items": {"type": "string"}},
        "brands": {"type": "array", "items": {"type": "string"}}
      }
    },
    "per_cell": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "rate_condition", "rate_bits", "brand", "mean_distortion"],
        "properties": {
          "model": {"type": "string"},
          "rate_condition": {"type": "string"},
          "rate_bits": {"type": "integer"},
          "brand": {"type": "string"},
          "n_valid": {"type": "integer"},
          "mean_distortion": {"type": "number", "minimum": 0, "maximum": 1},
          "std_distortion": {"type": "number", "minimum": 0}
        }
      }
    },
    "model_rd": {
      "type": "object",
      "description": "Per-model R(D) curve data and hypothesis tests.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "rate_bits": {"type": "array", "items": {"type": "number"}},
          "mean_distortions": {"type": "array", "items": {"type": "number"}},
          "rd_fit": {"type": "object"},
          "h1_spearman": {"type": "object"}
        }
      }
    },
    "cross_model_cv_by_rate": {
      "type": "object",
      "description": "Cross-model coefficient of variation by rate condition.",
      "additionalProperties": {"type": "number"}
    },
    "hypotheses": {
      "type": "object",
      "required": ["H1", "H2", "H3", "H4", "H5"],
      "properties": {
        "H1": {
          "type": "object",
          "required": ["verdict"],
          "properties": {
            "verdict": {"type": "string"},
            "bonferroni_alpha": {"type": "number"},
            "models_supported": {"type": "array"}
          }
        },
        "H2": {
          "type": "object",
          "required": ["verdict"],
          "properties": {
            "verdict": {"type": "string"},
            "mean_cv": {"type": ["number", "null"]},
            "threshold": {"type": "number"}
          }
        },
        "H3": {
          "type": "object",
          "required": ["verdict"],
          "properties": {"verdict": {"type": "string"}}
        },
        "H4": {
          "type": "object",
          "required": ["verdict"],
          "properties": {"verdict": {"type": "string"}}
        },
        "H5": {
          "type": "object",
          "required": ["verdict"],
          "properties": {
            "verdict": {"type": "string"},
            "cv_at_r1": {"type": ["number", "null"]},
            "threshold": {"type": "number"}
          }
        }
      }
    }
  },
  "additionalProperties": true
}
