{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orgschema.com/r15/aggregated_results.schema.json",
  "title": "R15 Aggregated Results",
  "description": "Aggregated per-run results files (results_v2_global.json, results_v3_local.json, results_v4_resolution.json). Generated by L4_analysis/aggregate_runs_2_to_4.py.",
  "type": "object",
  "required": [
    "run_id",
    "n_calls",
    "models",
    "dimensional_weights",
    "dci_aggregate",
    "schema_version"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Stable run identifier (e.g., 'run2_global')."
    },
    "description": {
      "type": "string"
    },
    "n_calls": {
      "type": "integer",
      "minimum": 0
    },
    "n_successful": {
      "type": "integer",
      "minimum": 0
    },
    "models": {
      "type": "array",
      "items": {"type": "string"}
    },
    "brand_pairs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "dimensional_weights": {
      "type": "object",
      "description": "Per-model mean weight allocation across 8 dimensions.",
      "additionalProperties": {
        "type": "object",
        "required": [
          "semiotic", "narrative", "ideological", "experiential",
          "social", "economic", "cultural", "temporal"
        ],
        "properties": {
          "semiotic": {"type": "number", "minimum": 0, "maximum": 100},
          "narrative": {"type": "number", "minimum": 0, "maximum": 100},
          "ideological": {"type": "number", "minimum": 0, "maximum": 100},
          "experiential": {"type": "number", "minimum": 0, "maximum": 100},
          "social": {"type": "number", "minimum": 0, "maximum": 100},
          "economic": {"type": "number", "minimum": 0, "maximum": 100},
          "cultural": {"type": "number", "minimum": 0, "maximum": 100},
          "temporal": {"type": "number", "minimum": 0, "maximum": 100}
        }
      }
    },
    "dci_per_model": {
      "type": "object",
      "additionalProperties": {"type": "number"}
    },
    "dci_aggregate": {
      "type": "object",
      "required": ["mean", "std", "n", "baseline"],
      "properties": {
        "mean": {"type": "number"},
        "std": {"type": "number", "minimum": 0},
        "n": {"type": "integer", "minimum": 0},
        "baseline": {"type": "number"},
        "h1_t_statistic": {"type": "number"},
        "h1_p_value": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "cosine_similarity": {
      "type": "object",
      "required": ["matrix", "model_order", "mean_pairwise"],
      "properties": {
        "matrix": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "number", "minimum": -1, "maximum": 1}
          }
        },
        "model_order": {
          "type": "array",
          "items": {"type": "string"}
        },
        "mean_pairwise": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      }
    },
    "source_files": {
      "type": "array",
      "items": {"type": "string"}
    },
    "schema_version": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
